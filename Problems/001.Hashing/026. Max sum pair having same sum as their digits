import java.util.*;

public class _01_hashing {

    static int digitSum(int a){
        int sum=0;
        while(a!=0) {
            sum += a % 10;
            a /= 10;
        }
        return sum;
    }

    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        Map<Integer, Integer> map = new HashMap<>();
        int n = sc.nextInt();
        int[] arr=new int[n];
        for(int i=0;i<n;i++){
            arr[i]=sc.nextInt();
        }

        int result=-1;
        int count=0;

        for(int i=0;i<n;i++){
            int digitSum=digitSum(arr[i]);
            if(!map.containsKey(digitSum)){
                map.put(digitSum,arr[i]);
            }
            else{
                int max=Math.max(result,arr[i]+map.get(digitSum));
                if(max==result){
                    count++;
                }
                else{
                    count=0;
                }
                result=max;

                map.put(digitSum,Math.max(arr[i],map.get(digitSum)));
            }

        }
        System.out.println(result);

    }
}



