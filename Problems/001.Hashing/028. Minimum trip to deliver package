//optimized:

/*


if a number is coming x number of times--> then we do x/3 is thats fully divisible then we add it to count
and if thats not fully divisible then we add 1 to x/3 and then we add it to count

eg: 15 --> 15/3=5 it takes 5 operations to finish

16 --> 16/3= 5 +1 --> 3,3,3,3,2,2
the last 3 will be converted to 2 and then leftover 1 is added to last leftover 1
so basically 1 extra operation will be there



 */


public class _03_Min_trip_to_deliver_packages {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int n = sc.nextInt();

        Map<Integer,Integer> map=new HashMap<>();


        for (int i = 0; i < n; i++) {
            int a=sc.nextInt();
            map.put(a,map.getOrDefault(a,0)+1);
        }

        int count=0;

        for(Map.Entry<Integer,Integer> entry:map.entrySet()){

            if(entry.getValue()==1){
                System.out.println("-1");
                return;
            }

            else{
                count+=entry.getValue()/3 + (entry.getValue()%3!=0 ? 1:0);
            }
        }
        System.out.println(count);


    }
}
