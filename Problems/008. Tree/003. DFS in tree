import java.util.Scanner;
import java.util.ArrayList;


public class _03_DFS_in_tree {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int nodes = sc.nextInt();
        int edges = sc.nextInt();

        ArrayList<Integer>[] arr = new ArrayList[nodes + 1];

        for (int i = 1; i <= nodes; i++) {
            arr[i] = new ArrayList<>();
        }

        for (int i = 1; i <= edges; i++) {
            int x = sc.nextInt();
            int y = sc.nextInt();

            arr[x].add(y);
            arr[y].add(x);

        }
        int[] visited = new int[nodes + 1];
        int[] parent = new int[nodes + 1];
        int[] height = new int[nodes + 1];


        dfs(1, arr, parent, visited, height);


        for (int i = 1; i <= nodes; i++) {
            System.out.println(height[i]);
        }

    }

    static void dfs(int node, ArrayList<Integer>[] arr, int[] parent, int[] visited, int[] height) {

        visited[node] = 1;

        for (int i : arr[node]) {
            if (visited[i] == 0) {
                visited[i] = 1;
                parent[i] = node;
                dfs(i, arr, parent, visited,height);
            }
        }
        System.out.println(node);
        /*
          Till here we have done the bottom up traversal
          now we are at leaf node,
          here we will start calculating the height of each node.
          and will move above so that for each node, we already have
          height of its child.


           we have parent array ready where,
           parent[i] tells the parent of node i.
           which we will use here,

           as when traversing the directly connected nodes of a node,
           child and parent will be directly connected to a node,
           and if some node does not have child
           so that node height will be miscalculated
           by adding its parent height.
           so we will handle that condition from parent array
           as if child ==parent[node]
           then ignore that.

            before that we will make a height array to store height of each node.

            now we will traverse each child of node. i.e src
        */


        int h = 0;
        for (int child : arr[node]) {
            if (child == parent[node]) {
                /*
                it means the child node is parent of the node
                and its not a child
                we ignore it

                 */
                continue;
            } else {
                h = Math.max(h, height[child]);
            }
        }


        height[node] = 1 + h;


    }


}
