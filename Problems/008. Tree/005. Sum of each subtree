package com.beginnerdsa.step3._8_Trees;


/*
given a tree of N nodes; rooted at node 1, find the sum of each
subtree "i" in the given tree.

eg:

       1
     /    \
    2      3
  /   \     \
 4     5     6

sum of 4 , 5, 6 is: their respective value.
sum of 2 is sum of node 4 and 5 i.e s(2)= value(2) + s(4) + s(5) = 1+1= 2
sum of 3 is value of 3 + sum(6) = 1 + 1 =2
sum of 1 is: value of 1 + sum(2) + sum(3) = 1 + 3 + 2= 6

so basically we will start calculating sum from bottom nodes as for above node
sum of their child nodes is required and for their child node, their child's child sum is required.
so we will start from bottom first.

hence dfs, will be used.
and for sum of a node we will add the value of each child of that node.
and that will solve the problem.


*/


import java.util.ArrayList;
import java.util.Scanner;

public class _05_sum_of_each_subtree {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        int nodes = sc.nextInt();
        int edges = sc.nextInt();
        int[] value=new int[nodes+1];


        ArrayList<Integer>[] arr = new ArrayList[nodes + 1];

        for (int i = 1; i <= nodes; i++) {
            arr[i] = new ArrayList<>();
        }

        for (int i = 1; i <= nodes; i++) {
            value[i] =sc.nextInt();
        }

        for (int i = 1; i <= edges; i++) {
            int x = sc.nextInt();
            int y = sc.nextInt();

            arr[x].add(y);
            arr[y].add(x);

        }
        int[] visited = new int[nodes + 1];
        int[] parent = new int[nodes + 1];
        int[] sum = new int[nodes + 1];



        dfs(1, arr, parent, visited, value,sum);


        for (int i = 1; i <= nodes; i++) {
            System.out.println(sum[i]);
        }

    }


    static void dfs(int node, ArrayList<Integer>[] arr, int[] parent, int[] visited, int[] value,int[] sum) {


        visited[node] = 1;

        for (int i : arr[node]) {
            if (visited[i] == 0) {
                visited[i] = 1;
                parent[i] = node;
                dfs(i, arr, parent, visited,value,sum);
            }
        }
        System.out.println(node);

        //here we will start finding child and will add their sum.

        int s=0;

        for(int child:arr[node]){
            if(child==parent[node]){
                continue;
                //as this is the parent of the node
            }
            else{
                s+=sum[child];
            }
            sum[node]=s+value[node];
        }
    }
}
